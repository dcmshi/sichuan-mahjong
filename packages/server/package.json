{
  "name": "sichuan-mahjong",
  "version": "0.1.0",
  "description": "Local 4-player Sichuan Mahjong (Bloody Rules) — host on your own machine",
  "type": "module",
  "bin": {
    "sichuan-mahjong": "./dist/main.js"
  },
  "files": ["dist/main.js", "dist/client"],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "bundle:client": "node scripts/bundle-client.mjs",
    "bundle:server": "node scripts/bundle-server.mjs",
    "prepack": "pnpm --filter @sichuan-mahjong/engine build && pnpm --filter @sichuan-mahjong/client build && tsc && node scripts/bundle-client.mjs && node scripts/bundle-server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.5",
    "multicast-dns": "^7.2.5",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@sichuan-mahjong/engine": "workspace:*",
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^25.9.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "vitest": "^3.2.6",
    "ws": "^8.20.1"
  }
}
